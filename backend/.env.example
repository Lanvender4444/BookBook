# LLM Provider Configuration
# Supported providers: anthropic, openai, deepseek, zhipu, qwen, qwen_intl, gemini, kimi, moonshot, siliconflow_intl
LLM_PROVIDER=anthropic

# Model name (depends on provider)
LLM_MODEL=claude-sonnet-4-20250514

# API Keys (fill in the one you use)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
ZHIPU_API_KEY=your_zhipu_key_here
QWEN_API_KEY=your_qwen_key_here
QWEN_INTL_API_KEY=your_qwen_intl_key_here
GEMINI_API_KEY=your_gemini_key_here
KIMI_API_KEY=your_kimi_key_here
MOONSHOT_API_KEY=your_moonshot_key_here
SILICONFLOW_INTL_API_KEY=your_siliconflow_intl_key_here

# Base URLs for OpenAI-compatible APIs (optional, defaults provided)
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_INTL_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
KIMI_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
SILICONFLOW_INTL_BASE_URL=https://api.siliconflow.com/v1

# Books Storage Directory (default: ~/BookBook)
BOOKS_DIR=C:/Users/YourName/BookBook

# P2P Settings
P2P_ENABLED=true
P2P_BROADCAST_PORT=47832
P2P_BOOK_PORT=47833

# Database
DATABASE_URL=sqlite:///./data/ebooks.db
